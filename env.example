# Database connection (same DB as backend, accessed via private VLAN)
DATABASE_URL="postgresql://user:password@db-host:5432/library_of_alexandria?schema=public"

# Gemini CLI configuration (CLI only, no API key needed)
# Auth: Run `gemini auth login` before starting the agent
# Quota: 1000 calls/day with CLI subscription
GEMINI_MODEL="gemini-2.0-flash-exp"

# Agent configuration
AGENT_WORKSPACE="/var/lib/loa-agent/workspace"
AGENT_LOG_LEVEL="info"
AGENT_DB_WRITE_GUARD="on"
AGENT_MEMORY_ROOT="/var/lib/loa-agent/memory"

# Cron schedule for daemon mode (default: every 30 minutes)
AGENT_CRON="*/30 * * * *"

# Limits
# Server: 2GB RAM / 1 CPU - comfortable for agent workloads
MAX_POSTS_PER_RUN=50
MAX_RETRIES=3
CODE_EXECUTION_TIMEOUT_MS=30000

# Posts per Gemini call
# Higher = more efficient (fewer API calls), but uses more memory
FORUM_BATCH_SIZE=500

# RLM scaffold limits (recursive language model tools)
RLM_ENABLED=true
RLM_CONTEXT_BYTES_THRESHOLD=800000
RLM_MIN_POSTS=80
RLM_MAX_STEPS=32
RLM_MAX_DEPTH=3
RLM_CHUNK_BYTES=16000
RLM_MAX_READ_BYTES=60000
RLM_MAX_SECTION_BYTES=200000
RLM_MAX_SEARCH_RESULTS=12
RLM_MAX_TOOL_RESULT_CHARS=8000

# Notifications (optional)
DISCORD_WEBHOOK_URL=""
DISCORD_NOTIFY_ON="task_failed,task_error,draft_created"
# Log levels: debug, info, warn, error, off
DISCORD_LOG_LEVEL="info"

# Discord Bot (optional)
# Usage: send "!onboard <slug> <content>" or use channel mapping
DISCORD_BOT_TOKEN=""
DISCORD_ONBOARD_PREFIX="!onboard"
# Comma-separated guild IDs allowed to onboard (empty = allow all)
DISCORD_ALLOWED_GUILD_IDS=""
# Comma-separated channel IDs allowed to onboard (empty = allow all)
DISCORD_ALLOWED_CHANNEL_IDS=""
# Map channel IDs to protocol slugs (JSON)
# Example: {"123456789012345678":{"slug":"aave"}}
DISCORD_ONBOARD_CHANNELS=""

# QMD (optional) - local memory search CLI
QMD_BIN="qmd"
QMD_INDEX=""

